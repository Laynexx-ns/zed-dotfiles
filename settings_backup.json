// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // -----------
  // LANGUAGE SETTINGS
  // -----------
  "show_edit_predictions": false,
  "edit_predictions": {
    "mode": "eager",
  },
  "use_system_prompts": true,
  "restore_on_startup": "last_session",
  "session": {
    "trust_all_worktrees": true,
  },

  "jsx_tag_auto_close": {
    "enabled": true,
  },

  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
            "tsserver": {
              "maxTsServerMemory": 16184,
            },
          },
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
            "tsserver": {
              "maxTsServerMemory": 16184,
            },
          },
        },
      },
      "enable_lsp_tasks": true,
    },
    "volar": {
      "settings": {
        "typescript": {
          "tsdk": "./node_modules/typescript/lib",
        },
      },
    },
    "rust-analyzer": {
      "initialization_options": {
        "inlayHints": {
          "maxLength": null,
          "lifetimeElisionHints": {
            "enable": "skip_trivial",
            "useParameterNames": true,
          },
          "closureReturnTypeHints": {
            "enable": "always",
          },
        },
      },
    },
  },

  "languages": {
    "JavaScript": {
      "tab_size": 2,
      "language_servers": ["!typescript-language-server", "vtsls"],
    },
    "TypeScript": {
      "tab_size": 2,
      "language_servers": ["!typescript-language-server", "vtsls"],
    },
    "Vue.js": {
      "tab_size": 2,
      "language_servers": [
        "!typescript-language-server",
        "vtsls",
        "emmet-language-server",
      ],
    },
    "Python": {
      "language_servers": ["ty"],
    },
  },

  "context_servers": {
    "postgres-context-server": {
      "enabled": true,
      "settings": {
        "database_url": "postgresql://postgres:postgres@postgres:5432/donly",
      },
    },
    "github-activity-summarizer": {
      "enabled": true,
      "settings": {},
    },
  },

  // SSH SETTINGS

  // PROFILES
  "profiles": {
    "presentation": {
      "buffer_font_size": 22,
      "ui_font_size": 18,
      "theme": "Modest Dark",
    },
  },

  // AI SETTINGS
  "agent": {
    "favorite_models": [
      {
        "provider": "google",
        "model": "gemini-3-pro-preview",
      },
      {
        "provider": "copilot_chat",
        "model": "gpt-5-mini",
      },
    ],
    "default_profile": "write",
    "dock": "left",
    "default_model": {
      "provider": "google",
      "model": "gemini-3-flash-preview",
    },
    "model_parameters": [],
  },
  "features": {
    "edit_prediction_provider": "zed",
  },

  // EDITOR UI
  "theme": "Aura Dark",
  "theme_overrides": {
    "Aura Dark": {
      "border.variant": "#15141C",
      "border": "#15141C",
      "surface.background": "#0000000",

      "title_bar.background": "#15141C",
      "panel.background": "#15141C",
      "panel.focused_border": "#4E466E",

      "players": [
        {
          "cursor": "#BD9DFF",
          "selection": "#BD9DFF88",
        },
      ],

      "syntax": {
        "comment": {
          "font_style": "italic",
        },
        "comment.doc": {
          "font_style": "italic",
        },
        "keyword": {
          "color": null,
          "font_style": "italic",
        },
      },
    },
  },
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Macchiato",
    "dark": "Puppet Icons",
  },
  "ui_font_size": 15,
  "buffer_font_size": 15,
  "buffer_line_height": "comfortable",
  "line_indicator_format": "long",
  "minimap": {
    "show": "never",
  },
  "bottom_dock_layout": "contained",

  // TERMINAL
  "terminal": {
    "toolbar": {
      "breadcrumbs": false,
    },
    "font_weight": 400.0,
    "font_size": 15,
    "font_family": "BlexMono Nerd Font Mono",
  },
  "colorize_brackets": true,
  "title_bar": {
    "show_branch_icon": false,
    "show_menus": true,
    "show_project_items": true,
  },

  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": true,
    "selections_menu": true,
    "agent_review": false,
    "code_actions": false,
  },
  "status_bar": {
    "experimental.show": true,
    "active_encoding_button": "disabled",
    "cursor_position_button": false,
    "line_endings_button": true,
  },

  "gutter": {
    "line_numbers": false,
    "runnables": true,
    "breakpoints": true,
    "folds": true,
    "min_line_number_digits": 1,
  },

  "tab_size": 2,

  "cursor_shape": "bar",
  "cursor_blink": false,
  "multi_cursor_modifier": "alt",

  "scrollbar": {
    // When to show the scrollbar in the editor (auto, system, always, never)
    "show": "system",
    "cursors": true, // Show cursor positions in the scrollbar.
    "git_diff": true, // Show git diff indicators in the scrollbar.
    "search_results": true, // Show buffer search results in the scrollbar.
    "selected_text": true, // Show selected text occurrences in the scrollbar.
    "selected_symbol": true, // Show selected symbol occurrences in the scrollbar.
    "diagnostics": "all", // Show diagnostics (none, error, warning, information, all)
    "axes": {
      "horizontal": true, // Show/hide the horizontal scrollbar
      "vertical": false, // Show/hide the vertical scrollbar
    },
  },

  "git_panel": {
    "tree_view": false,
    "button": true, // Show/hide status bar icon
    "dock": "left", // Where to dock: left, right
    "default_width": 360, // Default width of the git panel.
    "status_style": "icon", // label_color, icon
    "sort_by_path": false, // Sort by path (false) or status (true)
    "scrollbar": {
      "show": null, // Show/hide: (auto, system, always, never)
    },
  },

  // Debugger Panel
  "debugger": {
    "dock": "bottom", // Where to dock: left, right, bottom
    "button": true, // Show/hide status bar icon
  },

  // Outline Panel
  "outline_panel": {
    "button": true, // Show/hide status bar icon
    "default_width": 300, // Default width of the git panel
    "dock": "right", // Where to dock: left, right
    "file_icons": true, // Show/hide file_icons
    "folder_icons": true, // Show file_icons (true), chevrons (false) for dirs
    "git_status": true, // Show git status
    "indent_size": 20, // Indentation for nested items (pixels)
    "indent_guides": {
      "show": "always", // Show indent guides (always, never)
    },
    "auto_reveal_entries": true, // Show file in panel when activating its buffer
    "auto_fold_dirs": false, // Fold dirs with single subdir
    "scrollbar": {
      // Project panel scrollbar settings
      "show": null, // Show/hide: (auto, system, always, never)
    },
  },

  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },

  "disable_ai": false,
  "hide_mouse": "on_typing_and_movement",
  "project_panel": {
    "sort_mode": "directories_first",
    "hide_hidden": false,

    "button": false, // Show/hide button in the status bar
    "default_width": 200, // Default panel width
    "dock": "right", // Position of the dock (left, right)
    "entry_spacing": "standard", // Vertical spacing (comfortable, standard)
    "file_icons": true, // Show/hide file icons
    "folder_icons": true, // Show/hide folder icons
    "git_status": false, // Indicate new/updated files
    "indent_size": 30.0, // Pixels for each successive indent
    "auto_reveal_entries": true, // Show file in panel when activating its buffer
    "auto_fold_dirs": true, // Fold dirs with single subdir
    "sticky_scroll": true, // Stick parent directories at top of the project panel.
    "drag_and_drop": true, // Whether drag and drop is enabled
    "scrollbar": {
      // Project panel scrollbar settings
      "show": "never", // Show/hide: (auto, system, always, never)
    },
    "show_diagnostics": "all", //
    // Settings related to indent guides in the project panel.
    "indent_guides": {
      // When to show indent guides in the project panel. (always, never)
      "show": "always",
    },
    // Whether to hide the root entry when only one folder is open in the window.
    "hide_root": true,
  },
  "inlay_hints": {
    "enabled": false,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
    "show_background": false,
    "edit_debounce_ms": 700,
    "scroll_debounce_ms": 50,
    "toggle_on_modifiers_press": null,
  },

  "file_finder": {
    "git_status": true,
    "include_ignored": "smart",
    "skip_focus_for_active_in_search": true,
    "file_icons": false,
  },

  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },

  "whitespace_map": {
    "space": ".",
    "tab": "→",
  },

  //editor behaviour

  "vim_mode": false,

  // Project Panel Settings
  // "features": {
  //   "edit_prediction_provider": "none"
  // },
  "file_scan_exclusions": [],
  "format_on_save": "on",

  // other

  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
}
